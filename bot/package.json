{
  "name": "pensieve-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram capture bot for pensieve — a second writer into $PENSIEVE_HOME/raw",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
