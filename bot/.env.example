# Token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Comma-separated numeric Telegram user IDs allowed to use the bot (required).
# Message @userinfobot on Telegram to find your numeric id.
PENSIEVE_TG_ALLOWED_USERS=11111111,22222222

# --- Docker deployment ---
# Absolute host path to mount as the knowledge base. Use a real absolute path:
# neither Compose nor Node expand ~ or ${HOME} inside .env values. Inside the
# container this is always mounted at /data.
PENSIEVE_HOST_DIR=/Users/you/pensieve

# --- Local dev (npm run dev) ---
# Where notes are written when running outside Docker (absolute path). Ignored
# under Docker (the container forces PENSIEVE_HOME=/data).
PENSIEVE_HOME=/Users/you/pensieve

# Reject any single uploaded file larger than this many bytes (default 5 MiB).
PENSIEVE_MAX_FILE_BYTES=5242880

# Reject uploads once raw/assets would exceed this many bytes total (default 50 GiB).
PENSIEVE_MAX_TOTAL_BYTES=53687091200
