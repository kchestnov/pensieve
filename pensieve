#!/usr/bin/env zsh

set -euo pipefail

RAW="${PENSIEVE_HOME:-$HOME/pensieve}/raw"

# known capture types; anything else is rejected to keep frontmatter honest
typeset -r PENSIEVE_TYPES=(conversation article command snippet log todo)
pensieve_valid_type() {
    local t="$1" known
    for known in "${PENSIEVE_TYPES[@]}"; do
        [[ "$known" == "$t" ]] && return 0
    done
    return 1
}

pensieve_slugify() { print -r -- "$*" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]-' '-' | sed 's/^-*//;s/-*$//'; }

# pensieve_now_title — produce a stable timestamp for a single capture.
# Uses zsh/datetime's $EPOCHREALTIME for sub-second precision (macOS date(1)
# is BSD and lacks %N, and $RANDOM doesn't re-evaluate inside $(...) subshells).
pensieve_now_title() {
    zmodload -F zsh/datetime b: EPOCHREALTIME 2>/dev/null || zmodload zsh/datetime
    local sec=${EPOCHREALTIME%.*}
    local frac=${EPOCHREALTIME#*.}
    local stamp
    strftime -s stamp '%Y%m%d-%H%M%S' "$sec"
    printf '%s-%03d' "$stamp" "$((frac / 1000000 % 1000))"
}

# pensieve_nonblank <string> — 0 if the string has at least one non-whitespace char
pensieve_nonblank() {
    [[ -n "${1//[$' \t\n\r']/}" ]]
}

pensieve_die() { print -u2 -- "pensieve: $*"; exit 1; }

pensieve_write_note() {
    local type="$1" content="$2" asset="$3" context="$4" title="$5"
    local date_iso
    date_iso=$(date +%Y-%m-%dT%H:%M:%S)
    local note
    note=$(
        print -- "---"
        print -- "date: ${date_iso}"
        print -- "type: ${type}"
        print -- "tags: []"
        [[ -n "$context" ]] && print -- "context: ${context}"
        [[ -n "$asset" ]] && print -- "asset: ${asset}"
        print -- "---"
        print -- ""
        print -r -- "$content"
    )

    local file="${RAW}/${title}.md"
    mkdir -p "$RAW"
    print -r -- "$note" > "$file"
    print "Saved: $file"
}

pensieve_save_file() {
    local src="$1" type="$2" context="$3" title="$4"
    local ext="${src:e}"
    mkdir -p "${RAW}/assets"

    # dedupe: reuse existing asset if content is identical
    local src_sum existing dup_slug=""
    src_sum=$(md5 -q "$src")
    for existing in "${RAW}"/assets/*(N); do
        [[ "$(md5 -q "$existing")" == "$src_sum" ]] && dup_slug="${existing:t}" && break
    done

    local slug
    if [[ -n "$dup_slug" ]]; then
        slug="$dup_slug"
        print "Asset: duplicate, reusing ${RAW}/assets/${slug}"
    else
        slug="${title}-$(pensieve_slugify "${src:t:r}")${ext:+.$ext}"
        cp "$src" "${RAW}/assets/${slug}"
        print "Asset: ${RAW}/assets/${slug}"
    fi
    pensieve_write_note "$type" "[${src:t} — pending processing]" "assets/${slug}" "$context" "$title"
}

pensieve_list_lines() {
    local -a notes
    notes=("${RAW}"/*.md(N))
    [[ ${#notes[@]} -eq 0 ]] && return
    local f id title
    for f in "${(On)notes[@]}"; do
        id="${f:t:r}"
        title=$(awk '
            /^---$/ && NR > 1 { exit }
            /^type: /    { type = substr($0, 7) }
            /^context: / { ctx  = substr($0, 10) }
            END { print (length(ctx) > 0) ? ctx : "(" type ")" }
        ' "$f")
        printf '%-55s  %s\n' "$title" "$id"
    done
}

pensieve_rm_note() {
    local id="$1" file="${RAW}/${1}.md"
    [[ -f "$file" ]] || pensieve_die "note not found: ${id}"
    local asset
    asset=$(awk '/^asset: / { print substr($0, 8); exit }' "$file")
    [[ -n "$asset" ]] && rm -f "${RAW}/${asset}"
    rm -f "$file"
    print "Removed: ${id}"
}

pensieve_fzf_preview() {
    command -v bat &>/dev/null \
        && echo "bat --color=always --style=plain ${RAW}/{-1}.md" \
        || echo "cat ${RAW}/{-1}.md"
}

if [[ $# -eq 0 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    _help=$(cat <<'EOF'
## Usage

    pensieve @type [context words] [-- inline content]
    pensieve list
    pensieve edit

## Types

- `@conversation` — slack, email, any message fragment
- `@article`      — web, docs, reference material
- `@command`      — ready-to-run CLI invocation
- `@snippet`      — partial script, pattern, inspiration
- `@log`          — log output, errors, diagnostic artifacts
- `@todo`         — intent to implement, pipeline resolves into a Story

## Content sources

1. `--` inline content
2. file path argument(s)
3. stdin (piped)
4. clipboard file URL
5. clipboard text

Filename is always a timestamp. Context words go into frontmatter.
EOF
)
    if command -v bat &>/dev/null; then
        print -r -- "$_help" | bat -p --paging=never --language=md
    else
        print -r -- "$_help"
    fi
    exit 0
fi

[[ "$(uname -s)" == "Darwin" ]] || pensieve_die "pensieve requires macOS"

# internal subcommands used by fzf reload/execute bindings
if [[ "${1:-}" == "__lines" ]]; then
    [[ -d "$RAW" ]] && pensieve_list_lines
    exit 0
fi
if [[ "${1:-}" == "__rm" ]]; then
    [[ -n "${2:-}" ]] && pensieve_rm_note "${2}"
    exit 0
fi

if [[ "${1:-}" == "edit" ]]; then
    [[ -d "$RAW" ]] || pensieve_die "no notes yet: ${RAW}"
    typeset -a _edit_notes
    _edit_notes=("${RAW}"/*.md(N))
    [[ ${#_edit_notes[@]} -eq 0 ]] && pensieve_die "no notes to edit"
    ${=EDITOR:-vi} "${_edit_notes[-1]}"
    exit 0
fi

if [[ "${1:-}" == "list" ]]; then
    command -v fzf &>/dev/null || pensieve_die "fzf not found"
    [[ -d "$RAW" ]] || pensieve_die "no notes yet: ${RAW}"
    _fzf_env="PENSIEVE_HOME=${PENSIEVE_HOME:-$HOME/pensieve}"
    _fzf_bin="${0:A}"
    _list_sel=$(pensieve_list_lines | fzf --no-sort \
        --layout=reverse \
        --preview "$(pensieve_fzf_preview)" \
        --preview-window=down:60%:border-top \
        --bind 'ctrl-/:toggle-preview' \
        --bind "alt-o:execute(${EDITOR:-vi} ${RAW}/{-1}.md)" \
        --bind "alt-d:execute-silent(${_fzf_env} ${_fzf_bin} __rm {-1})+reload(${_fzf_env} ${_fzf_bin} __lines)" \
        --preview-label ' alt-o: edit · alt-d: delete ' \
        || true)
    [[ -n "$_list_sel" ]] && cat "${RAW}/${_list_sel##* }.md"
    exit 0
fi

note_type=""
if [[ "${1:-}" == @* ]]; then
    note_type="${1#@}"
    shift
    pensieve_valid_type "$note_type" || pensieve_die "unknown type @${note_type}; expected one of: ${PENSIEVE_TYPES[*]}"
fi
[[ -n "$note_type" ]] || pensieve_die "type required — use @${(j: | @:)PENSIEVE_TYPES}"

typeset -a pre_args=() post_args=()
saw_sep=0
for arg in "$@"; do
    if [[ "$arg" == "--" ]]; then saw_sep=1; continue; fi
    [[ $saw_sep -eq 0 ]] && pre_args+=("$arg") || post_args+=("$arg")
done

title=$(pensieve_now_title)

# -- inline content
if [[ $saw_sep -eq 1 ]]; then
    context="${pre_args[*]}"
    content="${post_args[*]}"
    pensieve_nonblank "$content" || pensieve_die "no content provided (empty '--' body)"
    pensieve_write_note "$note_type" "$content" "" "$context" "$title"
    exit 0
fi

# split pre_args into file args and context words; context is consumed by all paths below
typeset -a file_args=() context_args=()
for arg in "${pre_args[@]}"; do
    [[ -e "$arg" ]] && file_args+=("$arg") || context_args+=("$arg")
done
context="${context_args[*]}"

if [[ ${#file_args[@]} -gt 0 ]]; then
    # each file in the batch needs its own timestamp; pre-allocate so
    # note and asset filenames stay unique even within one second
    typeset -a batch_titles
    for _ in "${file_args[@]}"; do
        batch_titles+=("$(pensieve_now_title)")
    done
    typeset -i idx=1
    for f in "${file_args[@]}"; do
        pensieve_save_file "$f" "$note_type" "$context" "${batch_titles[$idx]}"
        (( idx++ ))
    done
    exit 0
fi

# stdin
if [[ ! -t 0 ]]; then
    content=$(head -c $((1024 * 1024 + 1)))
    (( ${#content} > 1024 * 1024 )) && pensieve_die "stdin exceeds 1 MB limit"
    pensieve_nonblank "$content" || pensieve_die "no content provided (stdin was empty)"
    pensieve_write_note "$note_type" "$content" "" "$context" "$title"
    exit 0
fi

# clipboard file URL
asset_src=$(osascript -e 'POSIX path of (the clipboard as «class furl»)' 2>/dev/null | tr -d '\n' || true)
if [[ -n "$asset_src" && -e "$asset_src" ]]; then
    pensieve_save_file "$asset_src" "$note_type" "$context" "$title"
    exit 0
fi

# clipboard text
content=$(pbpaste 2>/dev/null || true)
pensieve_nonblank "$content" || pensieve_die "no content provided (no --, no file, no stdin, clipboard empty)"
pensieve_write_note "$note_type" "$content" "" "$context" "$title"
